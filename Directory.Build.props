<Project>
  <PropertyGroup>
    <!-- Single source of truth for Novalist versioning.
         CI overrides these via -p:VersionPrefix=x.y.z on the dotnet publish command.
         Local/dev builds default to 0.0.1-dev. -->
    <VersionPrefix>1.13</VersionPrefix>
    <VersionSuffix Condition="'$(VersionSuffix)' == '' AND '$(ContinuousIntegrationBuild)' != 'true'">dev</VersionSuffix>

    <!-- These all derive from Version automatically, but we set them explicitly
         so InformationalVersion, FileVersion, and AssemblyVersion stay in sync. -->
    <AssemblyVersion>$(VersionPrefix).0</AssemblyVersion>
    <FileVersion>$(VersionPrefix).0</FileVersion>

    <!-- Product metadata -->
    <Product>Novalist</Product>
    <Company>Novalist</Company>
    <Copyright>Copyright © Novalist contributors</Copyright>

    <!-- Warnings we intentionally tolerate (Avalonia deprecations covered separately). -->
    <NoWarn>$(NoWarn);AVLN5001;AVLN3001;CS8618</NoWarn>
  </PropertyGroup>
</Project>
