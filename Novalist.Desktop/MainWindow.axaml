<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:Novalist.Desktop.ViewModels"
        xmlns:views="using:Novalist.Desktop.Views"
        xmlns:m="using:Novalist.Core.Models"
        xmlns:loc="using:Novalist.Desktop.Localization"
        xmlns:sdk="using:Novalist.Sdk.Models"
        xmlns:conv="using:Novalist.Desktop.Converters"
        mc:Ignorable="d"
        d:DesignWidth="1400" d:DesignHeight="900"
        x:Class="Novalist.Desktop.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding Title}"
        Background="{DynamicResource EditorBackground}"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen">

    <Panel>
    <DockPanel>
        <!-- Classic menu bar -->
        <Menu DockPanel.Dock="Top" IsVisible="{Binding IsAppChromeVisible}">
            <MenuItem Header="{loc:Loc menu.edit}">
                <MenuItem Header="{loc:Loc menu.commandPalette}"
                          Command="{Binding OpenCommandPaletteCommand}"
                          InputGesture="Ctrl+Shift+P" />
                <Separator />
                <MenuItem Header="{loc:Loc menu.findReplace}"
                          Command="{Binding OpenFindReplaceCommand}"
                          InputGesture="Ctrl+H" />
                <Separator />
                <MenuItem Header="{loc:Loc menu.addComment}"
                          Command="{Binding AddCommentCommand}"
                          InputGesture="Ctrl+Shift+M" />
                <MenuItem Header="{loc:Loc menu.addFootnote}"
                          Command="{Binding AddFootnoteCommand}"
                          InputGesture="Ctrl+Shift+F" />
                <Separator />
                <MenuItem Header="{loc:Loc menu.takeSnapshot}"
                          Command="{Binding TakeSnapshotCommand}" />
                <MenuItem Header="{loc:Loc menu.snapshots}"
                          Command="{Binding OpenSnapshotsCommand}" />
            </MenuItem>
            <MenuItem Header="{loc:Loc menu.view}">
                <MenuItem Header="{loc:Loc menu.toggleExplorer}"
                          Command="{Binding ToggleExplorerCommand}" />
                <MenuItem Header="{loc:Loc menu.toggleContextSidebar}"
                          Command="{Binding ToggleContextSidebarCommand}" />
                <MenuItem Header="{loc:Loc menu.toggleSceneNotes}"
                          Command="{Binding ToggleSceneNotesCommand}" />
                <Separator />
                <MenuItem Header="{loc:Loc menu.focusMode}"
                          Command="{Binding ToggleFocusModeCommand}"
                          InputGesture="F11" />
                <MenuItem Header="{loc:Loc menu.plotGrid}"
                          Command="{Binding OpenPlotGridCommand}" />
                <MenuItem Header="{loc:Loc menu.research}"
                          Command="{Binding OpenResearchCommand}" />
                <Separator />
                <MenuItem Header="{loc:Loc menu.toggleSplitEditor}"
                          Command="{Binding ToggleSplitEditorCommand}" />
            </MenuItem>
        </Menu>

        <!-- App Bar (slim, replaces ribbon) -->
        <Border DockPanel.Dock="Top"
                Classes="appBar"
                IsVisible="{Binding IsAppChromeVisible}">
            <Grid ColumnDefinitions="Auto,Auto,*,4,Auto,Auto,4,Auto,Auto,Auto,Auto"
                  VerticalAlignment="Center">
                <!-- Hamburger -->
                <Button Grid.Column="0"
                        Classes="appBarButton"
                        Command="{Binding ToggleStartMenuCommand}"
                        ToolTip.Tip="{loc:Loc ribbon.start}">
                    <Viewbox Classes="panelToggleIcon">
                        <Canvas Width="24" Height="24">
                            <Path Classes="panelToggleIcon" Data="M2,5 H22 M2,12 H22 M2,19 H22" />
                        </Canvas>
                    </Viewbox>
                </Button>
                <!-- Book picker -->
                <Button Grid.Column="1"
                        Classes="appBarButton appBarBookPicker"
                        Command="{Binding ToggleBookPickerCommand}"
                        ToolTip.Tip="{loc:Loc book.pickerTooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                        <TextBlock Text="{Binding ActiveBook.Name, FallbackValue=''}"
                                   VerticalAlignment="Center"
                                   MaxWidth="200"
                                   TextTrimming="CharacterEllipsis" />
                        <Border Background="{DynamicResource RibbonGroupBorder}"
                                Width="1" Height="14" Margin="6,0"
                                VerticalAlignment="Center" />
                        <TextBlock Text="{Binding ActiveDraftName, FallbackValue=''}"
                                   VerticalAlignment="Center"
                                   FontSize="{StaticResource FontSizeBodySmall}"
                                   Opacity="0.75"
                                   MaxWidth="140"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="▾" VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Opacity="0.6" />
                    </StackPanel>
                </Button>
                <!-- Draft picker (Flyout) -->
                <Button Grid.Column="1"
                        Classes="appBarButton"
                        Padding="6,4"
                        Margin="220,0,0,0"
                        HorizontalAlignment="Left"
                        ToolTip.Tip="{loc:Loc draft.pickerTooltip}"
                        IsVisible="{Binding IsProjectLoaded}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                        <TextBlock Text="{loc:Loc draft.label}" FontSize="{StaticResource FontSizeBodySmall}" Opacity="0.7" VerticalAlignment="Center" />
                        <TextBlock Text="▾" VerticalAlignment="Center" FontSize="{StaticResource FontSizeCaption}" Opacity="0.6" />
                    </StackPanel>
                    <Button.Flyout>
                        <Flyout Placement="Bottom">
                            <StackPanel MinWidth="220" Spacing="{StaticResource SpacingTighter}">
                                <TextBlock Text="{loc:Loc draft.listTitle}" Classes="statusPopupTitle" />
                                <ItemsControl ItemsSource="{Binding ActiveBookDrafts}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="m:BookDraftMetadata">
                                            <DockPanel>
                                                <Button DockPanel.Dock="Right"
                                                        Content="×"
                                                        Padding="6,0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).DeleteDraftCommand}"
                                                        CommandParameter="{Binding}" />
                                                <Button Classes="linkButton"
                                                        HorizontalAlignment="Stretch"
                                                        HorizontalContentAlignment="Left"
                                                        Padding="6,4"
                                                        Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).SwitchDraftCommand}"
                                                        CommandParameter="{Binding}">
                                                    <TextBlock Text="{Binding Name}" />
                                                </Button>
                                            </DockPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,4" />
                                <Button Content="{loc:Loc draft.add}"
                                        HorizontalAlignment="Stretch"
                                        Command="{Binding CreateDraftCommand}" />
                            </StackPanel>
                        </Flyout>
                    </Button.Flyout>
                </Button>
                <!-- Spacer (column 2) -->
                <!-- Gap (column 3 = 4px) -->
                <!-- +Chapter -->
                <Button Grid.Column="4"
                        Classes="appBarButton"
                        Command="{Binding Explorer.CreateChapterCommand}"
                        ToolTip.Tip="{loc:Loc ribbon.chapterTooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                        <Viewbox Classes="panelToggleIcon">
                            <Canvas Width="24" Height="24"><Path Classes="panelToggleIcon" Data="{StaticResource IconBook}"/></Canvas>
                        </Viewbox>
                        <TextBlock Text="{loc:Loc ribbon.chapter}" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBodySmall}" />
                    </StackPanel>
                </Button>
                <!-- +Scene -->
                <Button Grid.Column="5"
                        Classes="appBarButton"
                        Command="{Binding Explorer.CreateSceneCommand}"
                        ToolTip.Tip="{loc:Loc ribbon.sceneTooltip}">
                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                        <Viewbox Classes="panelToggleIcon">
                            <Canvas Width="24" Height="24"><Path Classes="panelToggleIcon" Data="{StaticResource IconFileText}"/></Canvas>
                        </Viewbox>
                        <TextBlock Text="{loc:Loc ribbon.scene}" VerticalAlignment="Center" FontSize="{StaticResource FontSizeBodySmall}" />
                    </StackPanel>
                </Button>
                <!-- Gap (column 6 = 4px) -->
                <!-- Explorer toggle -->
                <Button Grid.Column="7"
                        Classes="panelToggleButton"
                        Classes.active="{Binding IsExplorerVisible}"
                        Command="{Binding ToggleExplorerCommand}"
                        ToolTip.Tip="{loc:Loc ribbon.explorerTooltip}">
                    <Viewbox Classes="panelToggleIcon">
                        <Canvas Width="24" Height="24"><Path Classes="panelToggleIcon" Data="{StaticResource IconPanelLeft}"/></Canvas>
                    </Viewbox>
                </Button>
                <!-- Context sidebar toggle -->
                <Button Grid.Column="8"
                        Classes="panelToggleButton"
                        Classes.active="{Binding IsContextSidebarVisible}"
                        Command="{Binding ToggleContextSidebarCommand}"
                        ToolTip.Tip="{loc:Loc ribbon.contextSidebarTooltip}">
                    <Viewbox Classes="panelToggleIcon">
                        <Canvas Width="24" Height="24"><Path Classes="panelToggleIcon" Data="{StaticResource IconPanelRight}"/></Canvas>
                    </Viewbox>
                </Button>
                <!-- Scene notes toggle -->
                <Button Grid.Column="9"
                        Classes="panelToggleButton"
                        Classes.active="{Binding IsSceneNotesVisible}"
                        Command="{Binding ToggleSceneNotesCommand}"
                        ToolTip.Tip="{loc:Loc ribbon.sceneNotesTooltip}">
                    <Viewbox Classes="panelToggleIcon">
                        <Canvas Width="24" Height="24"><Path Classes="panelToggleIcon" Data="{StaticResource IconPanelBottom}"/></Canvas>
                    </Viewbox>
                </Button>
                <!-- Snapshots -->
                <Button Grid.Column="10"
                        Classes="panelToggleButton"
                        Command="{Binding OpenSnapshotsCommand}"
                        ToolTip.Tip="{loc:Loc ribbon.snapshotsTooltip}">
                    <TextBlock Text="{loc:Loc ribbon.snapshots}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"
                               Padding="6,0" />
                </Button>
            </Grid>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource RibbonBackground}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,4"
                IsVisible="{Binding IsProjectLoaded}">
            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="{StaticResource SpacingLarge}">
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            Spacing="{StaticResource SpacingNormal}"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource SpacingNormal}"
                                IsVisible="{Binding Editor.IsDocumentOpen}">
                        <TextBlock Text="{Binding Editor.WordCount, StringFormat='{}{0:N0} words'}"
                                   Classes="statusMetric"
                                   Foreground="{DynamicResource NormalText}">
                            <ToolTip.Tip>
                                <StackPanel>
                                    <TextBlock Text="{Binding Editor.CharacterCount, StringFormat='{}{0:N0} chars'}" />
                                    <TextBlock Text="{Binding Editor.CharacterCountWithoutSpaces, StringFormat='{}{0:N0} chars (no spaces)'}" />
                                </StackPanel>
                            </ToolTip.Tip>
                        </TextBlock>
                        <TextBlock Text="{Binding Editor.ReadingTimeDisplay}"
                                   Classes="statusMetric" />
                        <Border Classes="statusScoreBadge"
                                Background="{Binding Editor.ReadabilityColor}"
                                IsVisible="{Binding Editor.HasReadability}"
                                ToolTip.Tip="{Binding Editor.ReadabilityLevelLabel}">
                            <TextBlock Text="{Binding Editor.ReadabilityDisplay}"
                                       FontSize="{StaticResource FontSizeCaption}"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>
                    <TextBlock Text="{loc:Loc statusBar.openSceneHint}"
                               Classes="statusMetricDim"
                               IsVisible="{Binding Editor.IsDocumentOpen, Converter={x:Static BoolConverters.Not}}" />
                </StackPanel>

                <Button Grid.Column="1"
                        x:Name="ProjectOverviewButton"
                        Classes="statusOverviewButton"
                        Command="{Binding ToggleProjectOverviewCommand}"
                        IsEnabled="{Binding HasProjectOverview}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="{StaticResource SpacingNormal}"
                                VerticalAlignment="Center">
                        <TextBlock Text="{Binding ProjectTotalWordsDisplay}"
                                   Classes="statusMetric"
                                   Foreground="{DynamicResource NormalText}" />
                        <TextBlock Text="{Binding ProjectChapterCount, StringFormat='{}{0} ch'}"
                                   Classes="statusMetric" />
                        <TextBlock Text="{Binding ProjectSceneCount, StringFormat='{}{0} sc'}"
                                   Classes="statusMetric" />
                        <TextBlock Text="{Binding ProjectCharacterCount, StringFormat='{}{0} chars'}"
                                   Classes="statusMetric" />
                        <TextBlock Text="{Binding ProjectLocationCount, StringFormat='{}{0} loc'}"
                                   Classes="statusMetric" />
                        <TextBlock Text="{Binding ProjectReadingTimeDisplay}"
                                   Classes="statusMetricDim" />
                        <TextBlock Text="{Binding AverageChapterWordsDisplay, StringFormat='~ {0}/ch'}"
                                   Classes="statusMetricDim" />
                    </StackPanel>
                </Button>

                <!-- Bars share leftover space via `*` columns capped by MaxWidth, so
                     when the window narrows the ProgressBars shrink instead of the
                     trailing entries clipping off the right edge. -->
                <Grid Grid.Column="2"
                      ColumnDefinitions="Auto,Auto,Auto,*,Auto,*"
                      ColumnSpacing="{StaticResource SpacingNormal}"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right"
                      ToolTip.Tip="{Binding GoalTooltip}">
                    <!-- Extension status bar items -->
                    <ItemsControl Grid.Column="0" ItemsSource="{Binding ExtensionStatusBarItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingNormal}" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="vm:ExtensionStatusBarItemVM">
                                <Button Classes="statusOverviewButton"
                                        Padding="4,2"
                                        ToolTip.Tip="{Binding TooltipText}"
                                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ExecuteExtensionStatusBarItemCommand}"
                                        CommandParameter="{Binding Source}">
                                    <TextBlock Text="{Binding DisplayText}"
                                               Classes="statusMetric"
                                               Foreground="{DynamicResource NormalText}" />
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- Git status -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="{StaticResource SpacingSmall}"
                                IsVisible="{Binding IsInGitRepo}"
                                Margin="0,0,8,0">
                        <Button Classes="statusOverviewButton"
                                Command="{Binding ShowGitCommand}"
                                Padding="4,2">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingTighter}">
                                <TextBlock Text="{Binding GitBranchDisplay}"
                                           Classes="statusMetric"
                                           Foreground="{DynamicResource NormalText}" />
                                <TextBlock Text="{Binding GitChangedCount, StringFormat='{}{0} ✎'}"
                                           Classes="statusMetricDim" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                    <TextBlock Grid.Column="2"
                               Text="{Binding DailyGoalLabel}"
                               Classes="statusMetric"
                               Foreground="{DynamicResource NormalText}" />
                    <ProgressBar Grid.Column="3"
                                 Minimum="0"
                                 Maximum="100"
                                 MinWidth="24"
                                 MaxWidth="72"
                                 Height="4"
                                 HorizontalAlignment="Stretch"
                                 Value="{Binding DailyGoalPercent}" />
                    <TextBlock Grid.Column="4"
                               Text="{Binding ProjectGoalLabel}"
                               Classes="statusMetric"
                               Foreground="{DynamicResource NormalText}" />
                    <ProgressBar Grid.Column="5"
                                 Minimum="0"
                                 Maximum="100"
                                 MinWidth="24"
                                 MaxWidth="72"
                                 Height="4"
                                 HorizontalAlignment="Stretch"
                                 Value="{Binding ProjectGoalPercent}" />
                </Grid>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Panel>
            <!-- Welcome Screen (when no project loaded) -->
            <views:WelcomeView x:Name="WelcomeViewControl"
                                IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsProjectLoaded, Converter={x:Static BoolConverters.Not}}" />

            <!-- Project Content (when project loaded) -->
            <Grid x:Name="ProjectContentGrid" IsVisible="{Binding IsProjectLoaded}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="44" />
                    <ColumnDefinition Width="280" MinWidth="180" MaxWidth="500" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- Activity Bar -->
                <Border Grid.Column="0" Classes="activityBar">
                    <Grid RowDefinitions="*,Auto">
                        <!-- Top: project-scoped views -->
                        <StackPanel Grid.Row="0" Spacing="{StaticResource SpacingNone}" Margin="0,4,0,0">
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Dashboard}"
                                    Command="{Binding ShowDashboardCommand}"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.dashboardTooltip}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconBarChart}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Timeline}"
                                    Command="{Binding ShowTimelineCommand}"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.timelineTooltip}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconCalendar}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=CodexHub}"
                                    Command="{Binding ShowCodexHubCommand}"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.codexHubTooltip}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconBookOpen}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Manuscript}"
                                    Command="{Binding ShowManuscriptCommand}"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.manuscriptTooltip}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconScroll}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Calendar}"
                                    Command="{Binding OpenCalendarCommand}"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.calendarTooltip}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconCalendarDays}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=RelationshipsGraph}"
                                    Command="{Binding OpenRelationshipsGraphCommand}"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.relationshipsTooltip}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconUser}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveContentView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Maps}"
                                    Command="{Binding OpenMapsCommand}"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.mapsTooltip}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconMap}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Separator -->
                            <Border Height="1" Background="{DynamicResource RibbonBorder}" Margin="6,4" />
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveActivityView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Export}"
                                    Command="{Binding ShowActivityViewCommand}"
                                    CommandParameter="Export"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.export}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconUpload}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveActivityView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=ImageGallery}"
                                    Command="{Binding ShowActivityViewCommand}"
                                    CommandParameter="ImageGallery"
                                    IsVisible="{Binding IsProjectLoaded}"
                                    ToolTip.Tip="{loc:Loc ribbon.gallery}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconImage}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveActivityView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Git}"
                                    Command="{Binding ShowActivityViewCommand}"
                                    CommandParameter="Git"
                                    IsVisible="{Binding IsInGitRepo}"
                                    ToolTip.Tip="{loc:Loc ribbon.git}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconGitBranch}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <!-- Extension-contributed items -->
                            <ItemsControl ItemsSource="{Binding ExtensionActivityBarItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="sdk:ActivityBarItem">
                                        <Button Classes="activityBarButton"
                                                ToolTip.Tip="{Binding Tooltip}"
                                                Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).ExecuteExtensionActivityBarItemCommand}"
                                                CommandParameter="{Binding}">
                                            <Panel>
                                                <Viewbox Classes="activityBarIcon"
                                                         IsVisible="{Binding IconPath, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                    <Canvas Width="24" Height="24">
                                                        <Path Classes="activityBarIconPath"
                                                              Data="{Binding IconPath, Converter={x:Static conv:StringToGeometryConverter.Instance}}" />
                                                    </Canvas>
                                                </Viewbox>
                                                <TextBlock Text="{Binding Icon}" FontSize="{StaticResource FontSizeTitle}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           IsVisible="{Binding IconPath, Converter={x:Static StringConverters.IsNullOrEmpty}}" />
                                            </Panel>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                        <!-- Bottom: always-present -->
                        <StackPanel Grid.Row="1" Spacing="{StaticResource SpacingNone}" Margin="0,0,0,4">
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveActivityView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Extensions}"
                                    Command="{Binding ShowActivityViewCommand}"
                                    CommandParameter="Extensions"
                                    ToolTip.Tip="{loc:Loc extensions.title}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconPlug}"/></Canvas>
                                </Viewbox>
                            </Button>
                            <Button Classes="activityBarButton"
                                    Classes.active="{Binding ActiveActivityView, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Settings}"
                                    Command="{Binding ShowActivityViewCommand}"
                                    CommandParameter="Settings"
                                    ToolTip.Tip="{loc:Loc ribbon.settingsLabel}">
                                <Viewbox Classes="activityBarIcon">
                                    <Canvas Width="24" Height="24"><Path Classes="activityBarIconPath" Data="{StaticResource IconSettings}"/></Canvas>
                                </Viewbox>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Left Sidebar: stacked Explorer + Entity Panel -->
                          <Grid Grid.Column="1"
                              RowDefinitions="Auto,*"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              IsVisible="{Binding IsExplorerVisible}">
                    <!-- Sidebar mode tabs -->
                                        <Grid Grid.Row="0" ColumnDefinitions="*,*,*,Auto"
                          Background="{DynamicResource ExplorerBackground}">
                        <Button Grid.Column="0" Content="{loc:Loc sidebar.chapters}"
                                x:Name="SidebarChaptersTab"
                                Click="OnSidebarTabClick" Tag="Chapters"
                                Classes="explorerTab" Padding="10,6" FontSize="{StaticResource FontSizeBodySmall}"
                                Classes.active="{Binding ActiveSidebarTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Chapters}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="1" Content="{loc:Loc sidebar.entities}"
                                x:Name="SidebarEntitiesTab"
                                Click="OnSidebarTabClick" Tag="Entities"
                                Classes="explorerTab" Padding="10,6" FontSize="{StaticResource FontSizeBodySmall}"
                                Classes.active="{Binding ActiveSidebarTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=Entities}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        <Button Grid.Column="2" Content="{loc:Loc sidebar.smartLists}"
                                x:Name="SidebarSmartListsTab"
                                Click="OnSidebarTabClick" Tag="SmartLists"
                                Classes="explorerTab" Padding="10,6" FontSize="{StaticResource FontSizeBodySmall}"
                                Classes.active="{Binding ActiveSidebarTab, Converter={x:Static ObjectConverters.Equal}, ConverterParameter=SmartLists}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" />
                        <!-- Extension sidebar tabs -->
                        <ItemsControl Grid.Column="3" ItemsSource="{Binding ExtensionSidebarTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:ExtensionSidebarTabVM">
                                    <Button Content="{Binding Label}"
                                            Click="OnExtensionSidebarTabClick"
                                            Tag="{Binding Id}"
                                            Classes="explorerTab" Padding="10,6" FontSize="{StaticResource FontSizeBodySmall}"
                                            ToolTip.Tip="{Binding Tooltip}" />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Grid>

                                        <Panel Grid.Row="1">
                                                <!-- Chapter Explorer -->
                                                <views:ExplorerView DataContext="{Binding Explorer}"
                                                                                        x:Name="ExplorerPanel"
                                                                                        HorizontalAlignment="Stretch"
                                                                                        VerticalAlignment="Stretch" />

                                                <!-- Entity Panel -->
                                                <views:EntityPanelView DataContext="{Binding EntityPanel}"
                                                                                             x:Name="EntityPanelControl"
                                                                                             HorizontalAlignment="Stretch"
                                                                                             VerticalAlignment="Stretch"
                                                                                             IsVisible="False" />

                                                <!-- Smart Lists Panel -->
                                                <views:SmartListsPanelView DataContext="{Binding Explorer}"
                                                                                             x:Name="SmartListsPanelControl"
                                                                                             HorizontalAlignment="Stretch"
                                                                                             VerticalAlignment="Stretch"
                                                                                             IsVisible="False" />

                                                <!-- Extension sidebar panel host -->
                                                <ContentControl x:Name="ExtensionSidebarHost"
                                                                IsVisible="False"
                                                                HorizontalAlignment="Stretch"
                                                                VerticalAlignment="Stretch" />
                                        </Panel>
                                </Grid>

                <!-- Splitter -->
                <GridSplitter Grid.Column="2"
                              ResizeDirection="Columns"
                              IsVisible="{Binding IsExplorerVisible}" />

                <!-- Main Content Area -->
                <Grid Grid.Column="3">
                    <Grid Grid.Column="0"
                      RowDefinitions="Auto,*">
                    <Border Grid.Row="0"
                            Classes="editorTabStrip"
                            IsVisible="{Binding IsProjectLoaded}">
                        <ItemsControl ItemsSource="{Binding ContentTabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingNone}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:EditorTabDescriptor">
                                    <Border Classes="editorTabHost"
                                            Classes.active="{Binding IsActive}"
                                            Tag="{Binding Id}"
                                            PointerPressed="OnEditorTabPointerPressed">
                                        <Border.ContextMenu>
                                            <ContextMenu Tag="{Binding}">
                                                <MenuItem Header="{loc:Loc editor.tabClose}"
                                                          Click="OnTabContextCloseClick" />
                                                <MenuItem Header="{loc:Loc editor.tabMoveOther}"
                                                          Click="OnTabContextMoveClick" />
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid ColumnDefinitions="*,Auto" MinWidth="{Binding MinWidth}">
                                            <Button Grid.Column="0"
                                                    Classes="editorTabSurface"
                                                    Padding="12,10"
                                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SetActiveContentViewCommand}"
                                                    CommandParameter="{Binding ActivationKey}"
                                                    ToolTip.Tip="{Binding Tooltip}">
                                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}">
                                                    <Border Classes="editorTabBadge"
                                                            IsVisible="{Binding Badge, Converter={x:Static StringConverters.IsNotNullOrEmpty}}">
                                                        <TextBlock Text="{Binding Badge}" Classes="editorTabBadgeText" />
                                                    </Border>
                                                    <TextBlock Text="{Binding Title}" Classes="editorTabText" />
                                                    <Border Classes="editorTabDirtyDot" IsVisible="{Binding IsDirty}" />
                                                </StackPanel>
                                            </Button>
                                            <Button Grid.Column="1"
                                                    Classes="editorTabCloseButton"
                                                    Click="OnEditorTabCloseClick"
                                                    ToolTip.Tip="Close">
                                                <Path Classes="editorTabCloseGlyph" />
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Border>

                    <Grid Grid.Row="1">
                        <!-- Outer grid: [all panels] [shared ctx splitter] [shared ctx sidebar] -->
                        <Grid x:Name="OuterContentGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="0" MinWidth="0" MaxWidth="0" />
                            </Grid.ColumnDefinitions>

                            <!-- Column 0: all content panels stacked -->
                            <Grid Grid.Column="0">
                                <Grid x:Name="SceneContentPanel">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="0" MinWidth="0" MaxWidth="0" />
                                    </Grid.ColumnDefinitions>
                                    <Grid Grid.Column="0">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" MinHeight="80" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="180" MinHeight="60" />
                                        </Grid.RowDefinitions>
                                        <Grid Grid.Row="0" x:Name="EditorSplitGrid">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="0" />
                                                <ColumnDefinition Width="0" />
                                            </Grid.ColumnDefinitions>
                                            <views:EditorView Grid.Column="0"
                                                              DataContext="{Binding Editor}"
                                                              x:Name="EditorPanel" />
                                            <GridSplitter Grid.Column="1"
                                                          ResizeDirection="Columns"
                                                          Width="4"
                                                          IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSplitEditorOpen}" />
                                            <views:EditorView Grid.Column="2"
                                                              DataContext="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).SecondaryEditor}"
                                                              x:Name="SecondaryEditorPanel"
                                                              IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSplitEditorOpen}" />
                                        </Grid>

                                        <GridSplitter Grid.Row="1"
                                                      ResizeDirection="Rows"
                                                      IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSceneNotesVisible}" />

                                        <views:SceneNotesView Grid.Row="2"
                                                              DataContext="{Binding SceneNotes}"
                                                              IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSceneNotesVisible}" />
                                    </Grid>

                                    <!-- Extension right sidebar splitter -->
                                    <GridSplitter Grid.Column="1"
                                                  ResizeDirection="Columns"
                                                  IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsExtensionRightSidebarVisible}" />

                                    <!-- Extension right sidebar host -->
                                    <ContentControl Grid.Column="2"
                                                    x:Name="ExtensionRightSidebarHost"
                                                    IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsExtensionRightSidebarVisible}" />
                                </Grid>

                                <!-- Entity Editor -->
                                <views:EntityEditorView DataContext="{Binding EntityEditor}"
                                                         x:Name="EntityEditorPanel"
                                                         IsVisible="False" />

                                <!-- Dashboard -->
                                <views:DashboardView DataContext="{Binding Dashboard}"
                                                      x:Name="DashboardPanel"
                                                      IsVisible="False" />

                                <!-- Timeline -->
                                <views:TimelineView DataContext="{Binding Timeline}"
                                                     x:Name="TimelinePanel"
                                                     IsVisible="False" />

                                <!-- Export -->
                                <views:ExportView DataContext="{Binding Export}"
                                                   x:Name="ExportPanel"
                                                   IsVisible="False" />

                                <!-- Image Gallery -->
                                <views:ImageGalleryView DataContext="{Binding ImageGallery}"
                                                         x:Name="ImageGalleryPanel"
                                                         IsVisible="False" />

                                <!-- Git -->
                                <views:GitView DataContext="{Binding Git}"
                                                x:Name="GitPanel"
                                                IsVisible="False" />

                                <!-- Codex Hub -->
                                <views:CodexHubView DataContext="{Binding CodexHub}"
                                                     x:Name="CodexHubPanel"
                                                     IsVisible="False" />

                                <!-- Manuscript -->
                                <views:ManuscriptView DataContext="{Binding Manuscript}"
                                                       x:Name="ManuscriptPanel"
                                                       IsVisible="False" />

                                <!-- Maps -->
                                <views:MapView DataContext="{Binding Maps}"
                                               x:Name="MapsPanel"
                                               IsVisible="False" />

                                <!-- Plot Grid -->
                                <views:PlotGridView DataContext="{Binding PlotGrid}"
                                                    x:Name="PlotGridPanel"
                                                    IsVisible="False" />

                                <!-- Relationships graph -->
                                <views:RelationshipsGraphView DataContext="{Binding RelationshipsGraph}"
                                                              x:Name="RelationshipsGraphPanel"
                                                              IsVisible="False" />

                                <!-- Calendar -->
                                <views:CalendarView DataContext="{Binding Calendar}"
                                                    x:Name="CalendarPanel"
                                                    IsVisible="False" />

                                <!-- Research -->
                                <views:ResearchView DataContext="{Binding Research}"
                                                    x:Name="ResearchPanel"
                                                    IsVisible="False" />

                                <!-- Extension content views -->
                                <ContentControl x:Name="ExtensionContentHost" IsVisible="False" />
                            </Grid>

                            <!-- Shared context sidebar splitter (visible for Scene and Manuscript views) -->
                            <GridSplitter Grid.Column="1"
                                          ResizeDirection="Columns"
                                          IsVisible="{Binding IsContextSidebarShowing}" />

                            <!-- Context sidebar with optional extension tabs -->
                            <Grid Grid.Column="2"
                                  RowDefinitions="Auto,*"
                                  IsVisible="{Binding IsContextSidebarShowing}">
                                <!-- Tab strip: always shown so users can flip between Context / Footnotes / extension tabs -->
                                <Border Grid.Row="0"
                                        Background="{DynamicResource ExplorerBackground}"
                                        BorderBrush="{DynamicResource ExplorerBorder}"
                                        BorderThickness="1,0,0,1">
                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="{loc:Loc context.tab}"
                                                Click="OnContextTabClick" Tag="Context"
                                                Classes="explorerTab" Padding="10,6" FontSize="{StaticResource FontSizeBodySmall}"
                                                Classes.active="{Binding IsContextTabActive}" />
                                        <Button Content="{loc:Loc footnotes.tab}"
                                                Click="OnContextTabClick" Tag="Footnotes"
                                                Classes="explorerTab" Padding="10,6" FontSize="{StaticResource FontSizeBodySmall}"
                                                Classes.active="{Binding IsFootnotesTabActive}" />
                                        <ItemsControl ItemsSource="{Binding ExtensionContextTabs}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <StackPanel Orientation="Horizontal" />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:ExtensionContextTabVM">
                                                    <Button Content="{Binding Label}"
                                                            Click="OnContextExtTabClick"
                                                            Tag="{Binding Id}"
                                                            Classes="explorerTab" Padding="10,6" FontSize="{StaticResource FontSizeBodySmall}"
                                                            Classes.active="{Binding IsActive}"
                                                            ToolTip.Tip="{Binding Tooltip}" />
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                                <!-- Content: native context sidebar, footnotes panel, or extension panel -->
                                <Panel Grid.Row="1">
                                    <views:ContextSidebarView DataContext="{Binding ContextSidebar}"
                                                              x:Name="ContextSidebarPanel"
                                                              IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsContextTabActive}" />
                                    <views:FootnotesPanelView DataContext="{Binding FootnotesPanel}"
                                                              x:Name="FootnotesPanel"
                                                              IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsFootnotesTabActive}" />
                                    <ContentControl x:Name="ContextExtTabHost"
                                                    IsVisible="False" />
                                </Panel>
                            </Grid>
                        </Grid>
                    </Grid>
                </Grid>
                </Grid>
            </Grid>

            <Border IsVisible="{Binding IsProjectOverviewOpen}"
                    x:Name="ProjectOverviewOverlay"
                    Focusable="True"
                    Background="Transparent"
                    PointerPressed="OnProjectOverviewOverlayPressed">
                <Border CornerRadius="{StaticResource RadiusLarge}"
                        Width="460"
                        MinWidth="300"
                        MaxWidth="460"
                        MaxHeight="360"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Bottom"
                        Margin="0,0,0,26"
                        Background="{DynamicResource CardBackground}">
                    <Border Background="Transparent"
                            Padding="10,12"
                            PointerPressed="OnProjectOverviewPopupPressed">
                    <StackPanel Spacing="{StaticResource SpacingMedium}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="{loc:Loc project.renameProject}"
                                    Command="{Binding RenameProjectCommand}"
                                    Padding="8,2"
                                    FontSize="{StaticResource FontSizeBodySmall}"
                                    VerticalAlignment="Center" />
                            <TextBlock Text="{Binding ProjectName}"
                                       Classes="statusPopupTitle"
                                       VerticalAlignment="Center"
                                       TextTrimming="CharacterEllipsis" />
                        </DockPanel>

                        <Grid ColumnDefinitions="*,Auto,Auto"
                              ColumnSpacing="{StaticResource SpacingMedium}"
                              Margin="0,0,0,2">
                            <TextBlock Grid.Column="0"
                                       Text="{loc:Loc overview.chapterColumn}"
                                       Classes="statusPopupHeaderCell" />
                            <TextBlock Grid.Column="1"
                                       Text="{loc:Loc overview.wordsColumn}"
                                       Classes="statusPopupHeaderCell" />
                            <TextBlock Grid.Column="2"
                                       Text="{loc:Loc overview.readabilityColumn}"
                                       Classes="statusPopupHeaderCell" />
                        </Grid>

                        <ScrollViewer MaxHeight="300"
                                      HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="{loc:Loc overview.noChapters}"
                                           Classes="statusPopupBody"
                                           IsVisible="{Binding HasProjectOverview, Converter={x:Static BoolConverters.Not}}" />

                                <ItemsControl ItemsSource="{Binding ProjectOverviewChapters}"
                                              IsVisible="{Binding HasProjectOverview}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:StatusBarChapterOverviewItem">
                                            <StackPanel>
                                                <Border Classes="statusPopupRow">
                                                    <Grid ColumnDefinitions="*,Auto,Auto"
                                                          ColumnSpacing="{StaticResource SpacingMedium}">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding Name}"
                                                                   Classes="statusPopupName" />

                                                        <StackPanel Grid.Column="1"
                                                                    Orientation="Horizontal"
                                                                    Spacing="{StaticResource SpacingNone}"
                                                                    VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding WordCountDisplay}"
                                                                       Classes="statusPopupWords" />
                                                            <Border Classes="statusPopupMiniBar">
                                                                <Border Classes="statusPopupMiniBarFill"
                                                                        Width="{Binding BarWidth}" />
                                                            </Border>
                                                        </StackPanel>

                                                        <StackPanel Grid.Column="2"
                                                                    Orientation="Horizontal"
                                                                    Spacing="{StaticResource SpacingNone}"
                                                                    VerticalAlignment="Center">
                                                            <Border Classes="statusPopupReadabilityBadge"
                                                                    Background="{Binding ReadabilityColor}"
                                                                    IsVisible="{Binding HasReadability}">
                                                                <TextBlock Text="{Binding ReadabilityDisplay}"
                                                                           HorizontalAlignment="Center"
                                                                           FontSize="{StaticResource FontSizeCaption}"
                                                                           FontWeight="SemiBold"
                                                                           Foreground="White" />
                                                            </Border>
                                                            <TextBlock Text="{Binding ReadabilityLevelLabel}"
                                                                       Classes="statusPopupLevel"
                                                                       IsVisible="{Binding HasReadability}" />
                                                            <TextBlock Text="–"
                                                                       Classes="statusPopupNA"
                                                                       IsVisible="{Binding HasReadability, Converter={x:Static BoolConverters.Not}}" />
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>

                                                <ItemsControl ItemsSource="{Binding Scenes}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate x:DataType="vm:StatusBarSceneOverviewItem">
                                                            <Border Classes="statusPopupRow">
                                                                <Grid ColumnDefinitions="*,Auto,Auto"
                                                                      ColumnSpacing="{StaticResource SpacingMedium}">
                                                                    <TextBlock Grid.Column="0"
                                                                               Text="{Binding Name}"
                                                                               Margin="16,0,0,0"
                                                                               Classes="statusPopupSceneName" />

                                                                    <StackPanel Grid.Column="1"
                                                                                Orientation="Horizontal"
                                                                                Spacing="{StaticResource SpacingNone}"
                                                                                VerticalAlignment="Center">
                                                                        <TextBlock Text="{Binding WordCountDisplay}"
                                                                                   Classes="statusPopupSceneWords" />
                                                                        <Border Classes="statusPopupMiniBar">
                                                                            <Border Classes="statusPopupMiniBarFill"
                                                                                    Width="{Binding BarWidth}" />
                                                                        </Border>
                                                                    </StackPanel>

                                                                    <TextBlock Grid.Column="2"
                                                                               Text=""
                                                                               Classes="statusPopupNA" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </StackPanel>
                    </Border>
                </Border>
            </Border>

            <!-- Book Picker Overlay -->
            <Border IsVisible="{Binding IsBookPickerOpen}"
                    x:Name="BookPickerOverlay"
                    Focusable="True"
                    Background="{DynamicResource OverlayScrim}"
                    PointerPressed="OnBookPickerOverlayPressed">
                <Border CornerRadius="{StaticResource RadiusLarge}"
                        MinWidth="420"
                        MaxWidth="780"
                        MaxHeight="560"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Background="{DynamicResource CardBackground}"
                        PointerPressed="OnBookPickerPopupPressed">
                    <DockPanel Margin="16">
                        <TextBlock DockPanel.Dock="Top"
                                   Text="{loc:Loc book.pickerTitle}"
                                   Classes="statusPopupTitle"
                                   Margin="0,0,0,12" />

                        <Button DockPanel.Dock="Bottom"
                                Content="{loc:Loc book.addBook}"
                                Command="{Binding AddBookCommand}"
                                HorizontalAlignment="Right"
                                Margin="0,12,0,0" />

                        <TextBlock Text="{loc:Loc book.noBooks}"
                                   Classes="statusPopupBody"
                                   IsVisible="{Binding !BookCards.Count}" />

                        <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                                      VerticalScrollBarVisibility="Auto"
                                      IsVisible="{Binding BookCards.Count}">
                            <ItemsControl ItemsSource="{Binding BookCards}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:BookCard">
                                        <Button Classes="linkButton"
                                                Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).SelectBookFromPickerCommand}"
                                                CommandParameter="{Binding}"
                                                Padding="0"
                                                Margin="0,0,12,12">
                                            <Button.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{loc:Loc book.renameBook}" Click="OnBookCardRenameClick" />
                                                    <MenuItem Header="{loc:Loc book.deleteBook}" Click="OnBookCardDeleteClick" />
                                                </ContextMenu>
                                            </Button.ContextMenu>
                                            <Border Background="{DynamicResource CardBackground}"
                                                    BorderBrush="{DynamicResource CardBorder}"
                                                    BorderThickness="1"
                                                    Classes.active="{Binding IsActive}"
                                                    CornerRadius="{StaticResource RadiusLarge}"
                                                    Width="160"
                                                    ClipToBounds="True">
                                                <Border.Styles>
                                                    <Style Selector="Border.active">
                                                        <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </Style>
                                                </Border.Styles>
                                                <StackPanel>
                                                    <Panel Height="200">
                                                        <Image Source="{Binding CoverImage}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapInterpolationMode="HighQuality"
                                                               IsVisible="{Binding HasCoverImage}" />
                                                        <Border Background="{DynamicResource CardBackground}"
                                                                IsVisible="{Binding !HasCoverImage}">
                                                            <Viewbox Width="40" Height="40"
                                                                     HorizontalAlignment="Center" VerticalAlignment="Center">
                                                                <Canvas Width="24" Height="24">
                                                                    <Path StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round"
                                                                          Stroke="{DynamicResource SubtleText}"
                                                                          Data="{StaticResource IconBookOpen}"/>
                                                                </Canvas>
                                                            </Viewbox>
                                                        </Border>
                                                    </Panel>
                                                    <StackPanel Spacing="{StaticResource SpacingTightest}" Margin="10,8,10,10">
                                                        <TextBlock Text="{Binding Name}"
                                                                   FontWeight="SemiBold"
                                                                   FontSize="{StaticResource FontSizeBodyLarge}"
                                                                   Foreground="{DynamicResource NormalText}"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   MaxLines="1" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Border>

            <!-- Settings Overlay -->
            <views:SettingsView x:Name="SettingsViewControl"
                                 Focusable="True"
                                 IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsSettingsOpen}" />

            <!-- Extensions Overlay -->
            <views:ExtensionsView Focusable="True"
                                   DataContext="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).Extensions}"
                                   IsVisible="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).IsExtensionsOpen}" />

        </Panel>
    </DockPanel>

    <!-- Dialog Host Overlay — covers entire window for in-window modal dialogs -->
    <Border x:Name="DialogOverlay"
            Background="{DynamicResource OverlayScrim}"
            IsVisible="False"
            ZIndex="200">
        <Border CornerRadius="{StaticResource RadiusLarge}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="{DynamicResource CardBackground}">
            <ContentPresenter x:Name="DialogHostPresenter" />
        </Border>
    </Border>

    <!-- Start Menu Overlay (File-style backstage) — covers entire window including ribbon -->
    <Border IsVisible="{Binding IsStartMenuOpen}"
            x:Name="StartMenuOverlay"
            Background="{DynamicResource OverlayScrim}"
            Focusable="True"
            PointerPressed="OnStartMenuOverlayPressed">
        <Border x:Name="StartMenuPanel"
                HorizontalAlignment="Left"
                VerticalAlignment="Stretch"
                Width="280"
                Background="{DynamicResource ExplorerBackground}">
            <Border Background="Transparent"
                    PointerPressed="OnStartMenuPanelPressed">
                <DockPanel Margin="0,8">
                    <TextBlock DockPanel.Dock="Bottom"
                               Text="{Binding AppVersion}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               Opacity="0.45"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,8" />
                    <StackPanel>
                        <!-- Open Project -->
                        <Button Classes="startMenuItem"
                                Command="{Binding OpenProjectFromMenuCommand}"
                                ToolTip.Tip="{loc:Loc startMenu.openProjectTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingLarge}">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconFolderOpen}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc startMenu.openProject}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Recent Projects submenu -->
                        <Button Classes="startMenuItem">
                            <Button.Flyout>
                                <MenuFlyout Placement="RightEdgeAlignedTop">
                                    <ItemsControl ItemsSource="{Binding SettingsService.Settings.RecentProjects}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="m:RecentProject">
                                                <MenuItem Header="{Binding Name}"
                                                          Command="{Binding $parent[ItemsControl].((vm:MainWindowViewModel)DataContext).OpenRecentProjectFromMenuCommand}"
                                                          CommandParameter="{Binding}"
                                                          ToolTip.Tip="{Binding Path}" />
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </MenuFlyout>
                            </Button.Flyout>
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingLarge}">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconFolder}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc startMenu.recentProjects}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="12,6" />

                        <!-- Settings -->
                        <Button Classes="startMenuItem"
                                Command="{Binding ToggleSettingsCommand}"
                                ToolTip.Tip="{loc:Loc ribbon.settingsTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingLarge}">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconSettings}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc ribbon.settingsLabel}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Classes="startMenuItem"
                                Command="{Binding ToggleExtensionsCommand}"
                                ToolTip.Tip="{loc:Loc extensions.tooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingLarge}">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconPlug}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc extensions.title}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>

                        <!-- Separator -->
                        <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="12,6" />

                        <!-- Close Project -->
                        <Button Classes="startMenuItem"
                                Command="{Binding CloseProjectCommand}"
                                ToolTip.Tip="{loc:Loc startMenu.closeProjectTooltip}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingLarge}">
                                <Viewbox Width="16" Height="16" VerticalAlignment="Center">
                                    <Canvas Width="24" Height="24">
                                        <Path Classes="ribbonIcon" Data="{StaticResource IconBookOpen}" />
                                    </Canvas>
                                </Viewbox>
                                <TextBlock Text="{loc:Loc startMenu.closeProject}" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Border>
    </Border>
    <!-- Toast stack (click-dismiss) -->
    <ItemsControl ItemsSource="{Binding Toasts}"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Bottom"
                  Margin="0,0,0,52"
                  ZIndex="300">
        <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
                <StackPanel Orientation="Vertical" Spacing="{StaticResource SpacingMedium}" />
            </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
            <DataTemplate x:DataType="vm:ToastNotification">
                <Button Classes="toastButton"
                        Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).DismissToastCommand}"
                        CommandParameter="{Binding}"
                        Padding="0"
                        Background="Transparent"
                        BorderThickness="0">
                    <Border Padding="16,10"
                            CornerRadius="{StaticResource RadiusLarge}"
                            Background="{DynamicResource CardBackground}"
                            BorderBrush="{Binding Severity, Converter={x:Static conv:ToastSeverityToBrushConverter.Instance}}"
                            BorderThickness="3,1,1,1"
                            BoxShadow="0 4 12 0 #40000000">
                        <TextBlock Text="{Binding Message}"
                                   Foreground="{DynamicResource NormalText}"
                                   FontSize="{StaticResource FontSizeBodyLarge}" />
                    </Border>
                </Button>
            </DataTemplate>
        </ItemsControl.ItemTemplate>
    </ItemsControl>
    </Panel>
</Window>
