<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:views="using:Novalist.Desktop.Views"
             xmlns:loc="using:Novalist.Desktop.Localization"
             mc:Ignorable="d"
             d:DesignWidth="800" d:DesignHeight="600"
             x:Class="Novalist.Desktop.Views.EditorView"
             x:DataType="vm:EditorViewModel">

    <Grid RowDefinitions="Auto,Auto,*">
        <!-- Per-pane scene tab strip (visible whenever any scene tab is open) -->
        <Border Grid.Row="0"
                IsVisible="{Binding HasOpenScenes}"
                Background="{DynamicResource EditorTabsBackground}"
                BorderBrush="{DynamicResource RibbonBorder}"
                BorderThickness="0,0,0,1">
            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding OpenScenes}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingNone}" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:EditorOpenScene">
                            <Border Classes="editorTabHost"
                                    Classes.active="{Binding IsActive}"
                                    Tag="{Binding}"
                                    PointerPressed="OnTabPointerPressed">
                                <Border.ContextMenu>
                                    <ContextMenu Tag="{Binding}">
                                        <MenuItem Header="{loc:Loc editor.tabClose}"
                                                  Click="OnTabContextCloseClick" />
                                        <MenuItem Header="{loc:Loc editor.tabMoveOther}"
                                                  Click="OnTabContextMoveClick" />
                                    </ContextMenu>
                                </Border.ContextMenu>
                                <Grid ColumnDefinitions="*,Auto" MinWidth="160">
                                    <Button Grid.Column="0"
                                            Classes="editorTabSurface"
                                            Padding="12,8"
                                            Command="{Binding $parent[UserControl].((vm:EditorViewModel)DataContext).ActivateTabFromUiCommand}"
                                            CommandParameter="{Binding}">
                                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingSmall}">
                                            <TextBlock Text="{Binding DisplayTitle}" Classes="editorTabText" />
                                            <Border Classes="editorTabDirtyDot" IsVisible="{Binding IsDirty}" />
                                        </StackPanel>
                                    </Button>
                                    <Button Grid.Column="1"
                                            Classes="editorTabCloseButton"
                                            Click="OnTabCloseClick"
                                            Tag="{Binding}">
                                        <Path Classes="editorTabCloseGlyph" />
                                    </Button>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Archived-scene banner: read-only notice + Restore action -->
        <Border Grid.Row="1"
                IsVisible="{Binding IsCurrentSceneArchived}"
                Background="#332196F3"
                BorderBrush="#5592C8"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <Button DockPanel.Dock="Right"
                        Content="{loc:Loc editor.archiveBanner.restore}"
                        Padding="10,4"
                        Margin="6,0,0,0"
                        Command="{Binding RestoreCurrentArchivedSceneCommand}" />
                <TextBlock Text="{loc:Loc editor.archiveBanner.text}"
                           Foreground="{DynamicResource NormalText}"
                           VerticalAlignment="Center"
                           TextWrapping="Wrap" />
            </DockPanel>
        </Border>

        <Grid Grid.Row="2" x:Name="EditorHost">
            <!-- WebView is created in code-behind so we can catch native init
                 failures (e.g. Xamarin.Mac / .NET 10 incompatibility on macOS). -->

            <!-- Empty state overlay — on top, hides when a document is open -->
            <Border Background="{DynamicResource EditorBackground}"
                    IsVisible="{Binding !IsDocumentOpen}"
                    IsHitTestVisible="False">
                <StackPanel VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Spacing="{StaticResource SpacingMedium}">
                    <TextBlock Text="{loc:Loc editor.emptyState}"
                               FontSize="{StaticResource FontSizeTitle}"
                               Foreground="{DynamicResource SubtleText}"
                               HorizontalAlignment="Center" />
                </StackPanel>
            </Border>

            <Popup x:Name="FocusPeekPopup"
                   Placement="AnchorAndGravity"
                   PlacementAnchor="TopLeft"
                   PlacementGravity="BottomRight"
                   IsOpen="{Binding FocusPeek.IsOpen}"
                   HorizontalOffset="{Binding FocusPeek.Left}"
                   VerticalOffset="{Binding FocusPeek.Top}"
                   IsLightDismissEnabled="False"
                   TakesFocusFromNativeControl="False"
                   WindowManagerAddShadowHint="False">
                <views:FocusPeekCardView DataContext="{Binding FocusPeek}"
                                         IsHitTestVisible="True" />
            </Popup>

        </Grid>
    </Grid>
</UserControl>
