<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:Novalist.Desktop.ViewModels"
             xmlns:loc="using:Novalist.Desktop.Localization"
             xmlns:views="using:Novalist.Desktop.Views"
             mc:Ignorable="d"
             d:DesignWidth="900" d:DesignHeight="700"
             x:Class="Novalist.Desktop.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">

    <Border Background="{DynamicResource ExplorerBackground}">
    <Grid ColumnDefinitions="220,*">

        <!-- ═══ LEFT SIDEBAR ═══ -->
        <Border Grid.Column="0"
                BorderBrush="{DynamicResource RibbonGroupBorder}"
                BorderThickness="0,0,1,0"
                Padding="0,16,0,0">
            <DockPanel>
                <!-- Header + Close -->
                <DockPanel DockPanel.Dock="Top" Margin="16,0,16,12">
                    <Button DockPanel.Dock="Right"
                            Content="✕"
                            x:Name="CloseButton"
                            Classes="ribbonButton"
                            FontSize="{StaticResource FontSizeTitleSmall}"
                            Padding="6,2"
                            VerticalAlignment="Center"
                            AutomationProperties.Name="{loc:Loc dialog.close}"
                            ToolTip.Tip="{loc:Loc dialog.close}" />
                    <TextBlock Text="{loc:Loc settings.title}"
                               FontSize="{StaticResource FontSizeTitle}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource NormalText}"
                               VerticalAlignment="Center" />
                </DockPanel>

                <!-- Search Box -->
                <Border DockPanel.Dock="Top" Margin="16,0,16,16">
                    <TextBox x:Name="SearchBox"
                             Text="{Binding SearchQuery, Mode=TwoWay}"
                             Watermark="{loc:Loc settings.searchPlaceholder}"
                             FontSize="{StaticResource FontSizeBody}"
                             Padding="8,6" />
                </Border>

                <!-- Category List -->
                <ListBox ItemsSource="{Binding Categories}"
                         SelectedItem="{Binding SelectedCategory}"
                         Margin="0"
                         Background="Transparent"
                         BorderThickness="0"
                         Padding="0">
                    <ListBox.Styles>
                        <Style Selector="ListBoxItem">
                            <Setter Property="Padding" Value="24,8"/>
                            <Setter Property="FontSize" Value="{StaticResource FontSizeBodyLarge}"/>
                            <Setter Property="Foreground" Value="{DynamicResource NormalText}"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="CornerRadius" Value="{StaticResource RadiusNone}"/>
                            <Setter Property="BorderThickness" Value="3,0,0,0"/>
                            <Setter Property="BorderBrush" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:selected">
                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                        <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter#PART_ContentPresenter">
                            <Setter Property="Background" Value="{DynamicResource CardBackground}"/>
                        </Style>
                    </ListBox.Styles>
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:SettingsCategoryItem">
                            <TextBlock Text="{Binding DisplayName}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- ═══ MAIN SETTINGS AREA ═══ -->
        <ScrollViewer Grid.Column="1"
                      x:Name="SettingsScrollViewer"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="40,24,40,40" Spacing="32" MaxWidth="640">

                <!-- ── Appearance Section ── -->
                <StackPanel x:Name="SectionAppearance" Spacing="{StaticResource SpacingXL}"
                            IsVisible="{Binding IsAppearanceSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.appearance}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <CheckBox IsChecked="{Binding AppearanceScopeProject}"
                              IsEnabled="{Binding CanUseProjectScope}"
                              Content="{loc:Loc settings.scopeProjectOverride}"
                              ToolTip.Tip="{loc:Loc settings.scopeProjectHint}"
                              FontSize="{StaticResource FontSizeBodySmall}" />

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                            <TextBlock Text="{loc:Loc settings.uiLanguage}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.uiLanguageDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}" />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AvailableUiLanguages}"
                                  SelectedItem="{Binding SelectedUiLanguage}"
                                  MinWidth="200"
                                  HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Theme -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                            <TextBlock Text="{loc:Loc settings.theme}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.themeDescription}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}" />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AvailableThemes}"
                                  SelectedItem="{Binding SelectedTheme}"
                                  MinWidth="200"
                                  HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Accent Color -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                            <TextBlock Text="{loc:Loc settings.accentColor}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.accentColorDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}" HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                            <ColorPicker Color="{Binding AccentColor}"
                                         IsAlphaVisible="False" />
                            <Button Content="{loc:Loc settings.accentColorReset}"
                                    Command="{Binding ResetAccentColorCommand}"
                                    Padding="8,4"
                                    FontSize="{StaticResource FontSizeBodySmall}" />
                        </StackPanel>
                    </DockPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Editor Section ── -->
                <StackPanel x:Name="SectionEditor" Spacing="{StaticResource SpacingXL}"
                            IsVisible="{Binding IsEditorSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.editor}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <CheckBox IsChecked="{Binding EditorScopeProject}"
                              IsEnabled="{Binding CanUseProjectScope}"
                              Content="{loc:Loc settings.scopeProjectOverride}"
                              ToolTip.Tip="{loc:Loc settings.scopeProjectHint}"
                              FontSize="{StaticResource FontSizeBodySmall}" />

                    <!-- Font Family -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                            <TextBlock Text="{loc:Loc settings.fontFamily}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.fontFamilyDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}" />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AvailableFonts}"
                                  SelectedItem="{Binding EditorFontFamily}"
                                  MinWidth="200"
                                  HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Font Size -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                            <TextBlock Text="{loc:Loc settings.fontSize}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.fontSizeDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}" />
                        </StackPanel>
                        <NumericUpDown Value="{Binding EditorFontSize}"
                                       Minimum="8"
                                       Maximum="36"
                                       Increment="1"
                                       FormatString="0"
                                       MinWidth="120"
                                       HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Book Paragraph Spacing -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc settings.bookSpacing}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.bookSpacingDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding EnableBookParagraphSpacing}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <!-- Typewriter Scroll -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc settings.typewriterScroll}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.typewriterScrollDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding TypewriterScrollEnabled}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingLarge}"
                                IsVisible="{Binding TypewriterScrollEnabled}"
                                HorizontalAlignment="Right">
                        <RadioButton GroupName="TypewriterAnchor"
                                     Content="{loc:Loc settings.typewriterAnchorTop}"
                                     IsChecked="{Binding TypewriterAnchorTop}" />
                        <RadioButton GroupName="TypewriterAnchor"
                                     Content="{loc:Loc settings.typewriterAnchorMiddle}"
                                     IsChecked="{Binding TypewriterAnchorMiddle}" />
                        <RadioButton GroupName="TypewriterAnchor"
                                     Content="{loc:Loc settings.typewriterAnchorBottom}"
                                     IsChecked="{Binding TypewriterAnchorBottom}" />
                    </StackPanel>

                    <!-- Page View -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc settings.pageView}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.pageViewDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding PageViewEnabled}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <!-- Book Page Width -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc settings.bookWidth}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.bookWidthDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding EnableBookWidth}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <StackPanel Spacing="{StaticResource SpacingLarge}"
                                IsVisible="{Binding EnableBookWidth}">
                        <!-- Page Format -->
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                                <TextBlock Text="{loc:Loc settings.bookWidthPageFormat}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}" />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding AvailablePageFormats}"
                                      SelectedItem="{Binding SelectedPageFormat}"
                                      MinWidth="200"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <!-- Custom Width -->
                        <DockPanel IsVisible="{Binding IsCustomPageFormat}">
                            <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                                <TextBlock Text="{loc:Loc settings.bookWidthCustom}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}" />
                                <TextBlock Text="{loc:Loc settings.bookWidthCustomDesc}"
                                           Foreground="{DynamicResource SubtleText}"
                                           FontSize="{StaticResource FontSizeBodySmall}" />
                            </StackPanel>
                            <NumericUpDown Value="{Binding BookTextBlockWidth}"
                                           Minimum="2"
                                           Maximum="10"
                                           Increment="0.25"
                                           FormatString="0.##"
                                           MinWidth="120"
                                           HorizontalAlignment="Right" />
                        </DockPanel>

                        <!-- Book Font -->
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                                <TextBlock Text="{loc:Loc settings.bookWidthFont}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}" />
                            </StackPanel>
                            <ComboBox ItemsSource="{Binding AvailableFonts}"
                                      SelectedItem="{Binding BookFontFamily}"
                                      MinWidth="200"
                                      HorizontalAlignment="Right" />
                        </DockPanel>

                        <!-- Book Font Size -->
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="200">
                                <TextBlock Text="{loc:Loc settings.bookWidthFontSize}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}" />
                            </StackPanel>
                            <NumericUpDown Value="{Binding BookFontSize}"
                                           Minimum="6"
                                           Maximum="24"
                                           Increment="0.5"
                                           FormatString="0.#"
                                           MinWidth="120"
                                           HorizontalAlignment="Right" />
                        </DockPanel>

                        <!-- Chars per line preview -->
                        <TextBlock Text="{Binding BookWidthCharsPerLine}"
                                   Foreground="{DynamicResource SubtleText}"
                                   FontSize="{StaticResource FontSizeBodySmall}"
                                   FontStyle="Italic" />
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Writing Goals Section ── -->
                <StackPanel x:Name="SectionWritingGoals" Spacing="{StaticResource SpacingXL}"
                            IsVisible="{Binding IsWritingGoalsSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.writingGoals}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <Border Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="16,12">
                        <DockPanel>
                            <Button DockPanel.Dock="Right"
                                    Content="{loc:Loc project.renameProject}"
                                    Command="{Binding $parent[Window].((vm:MainWindowViewModel)DataContext).RenameProjectCommand}"
                                    Padding="10,4"
                                    VerticalAlignment="Center" />
                            <StackPanel Spacing="{StaticResource SpacingTighter}">
                                <TextBlock Text="{Binding CurrentProjectName}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{loc:Loc settings.goalsDesc}"
                                           Foreground="{DynamicResource SubtleText}"
                                           FontSize="{StaticResource FontSizeBodySmall}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="300">
                            <TextBlock Text="{loc:Loc settings.dailyWordGoal}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.dailyWordGoalDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <NumericUpDown Value="{Binding DailyWordGoal}"
                                       Minimum="0"
                                       Maximum="1000000"
                                       Increment="100"
                                       FormatString="0"
                                       MinWidth="140"
                                       HorizontalAlignment="Right" />
                    </DockPanel>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="300">
                            <TextBlock Text="{loc:Loc settings.projectWordGoal}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.projectWordGoalDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <NumericUpDown Value="{Binding ProjectWordGoal}"
                                       Minimum="0"
                                       Maximum="10000000"
                                       Increment="1000"
                                       FormatString="0"
                                       MinWidth="140"
                                       HorizontalAlignment="Right" />
                    </DockPanel>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="300">
                            <TextBlock Text="{loc:Loc settings.projectDeadline}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.projectDeadlineDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBox Text="{Binding ProjectDeadline}"
                                 Watermark="{loc:Loc common.dateWatermarkIso}"
                                 MinWidth="140"
                                 HorizontalAlignment="Right" />
                    </DockPanel>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="300">
                            <TextBlock Text="{loc:Loc settings.projectAuthor}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.projectAuthorDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBox Text="{Binding ProjectAuthor}"
                                 MinWidth="220"
                                 HorizontalAlignment="Right" />
                    </DockPanel>

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc settings.watchFilesystem}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.watchFilesystemDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding WatchFilesystem}"
                                      IsEnabled="{Binding CanUseProjectScope}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Writing Assistance Section ── -->
                <StackPanel x:Name="SectionWritingAssistance" Spacing="{StaticResource SpacingXL}"
                            IsVisible="{Binding IsWritingAssistanceSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.writingAssistance}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <CheckBox IsChecked="{Binding WritingScopeProject}"
                              IsEnabled="{Binding CanUseProjectScope}"
                              Content="{loc:Loc settings.scopeProjectOverride}"
                              ToolTip.Tip="{loc:Loc settings.scopeProjectHint}"
                              FontSize="{StaticResource FontSizeBodySmall}" />

                    <!-- Language -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="300">
                            <TextBlock Text="{loc:Loc settings.quoteStyle}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.quoteStyleDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ComboBox ItemsSource="{Binding AvailableLanguages}"
                                  SelectedItem="{Binding SelectedLanguage}"
                                  MinWidth="200"
                                  HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Dialogue Correction -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="300">
                            <TextBlock Text="{loc:Loc settings.dialogueCorrection}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.dialogueCorrectionDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding DialogueCorrectionEnabled}"
                                      HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Grammar Check -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="300">
                            <TextBlock Text="{loc:Loc settings.grammarCheck}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.grammarCheckDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding GrammarCheckEnabled}"
                                      HorizontalAlignment="Right" />
                    </DockPanel>

                    <!-- Preview -->
                    <Border Background="{DynamicResource CardBackground}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="{StaticResource RadiusMedium}"
                            Padding="16,12">
                        <StackPanel Spacing="{StaticResource SpacingTighter}">
                            <TextBlock Text="{loc:Loc settings.preview}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource SubtleText}" />
                            <TextBlock Text="{Binding AutoReplacementPreview}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                       TextWrapping="Wrap"
                                       FontFamily="{DynamicResource MonoFontFamily}" />
                        </StackPanel>
                    </Border>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Templates Section ── -->
                <StackPanel x:Name="SectionTemplates" Spacing="{StaticResource SpacingMedium}"
                            IsVisible="{Binding IsTemplatesSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.templates}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <!-- Character Templates -->
                    <Expander IsExpanded="False" Padding="0">
                        <Expander.Header>
                            <DockPanel>
                                <TextBlock Text="{loc:Loc settings.characterTemplates}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Content="+"
                                        Command="{Binding AddCharacterTemplateCommand}"
                                        Padding="8,4"
                                        FontSize="{StaticResource FontSizeTitleSmall}"
                                        HorizontalAlignment="Right"
                                        ToolTip.Tip="{loc:Loc template.addTemplate}" />
                            </DockPanel>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{Binding CharacterTemplates}" Margin="16,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TemplateListItem">
                                    <DockPanel Margin="0,2">
                                        <Button Content="&#xE711;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="{StaticResource FontSizeBody}"
                                                Padding="6"
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).DeleteCharacterTemplateCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc template.delete}" />
                                        <Button Content="{Binding Name}"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Foreground="{DynamicResource NormalText}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).EditCharacterTemplateCommand}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <!-- Location Templates -->
                    <Expander IsExpanded="False" Padding="0">
                        <Expander.Header>
                            <DockPanel>
                                <TextBlock Text="{loc:Loc settings.locationTemplates}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Content="+"
                                        Command="{Binding AddLocationTemplateCommand}"
                                        Padding="8,4"
                                        FontSize="{StaticResource FontSizeTitleSmall}"
                                        HorizontalAlignment="Right"
                                        ToolTip.Tip="{loc:Loc template.addTemplate}" />
                            </DockPanel>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{Binding LocationTemplates}" Margin="16,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TemplateListItem">
                                    <DockPanel Margin="0,2">
                                        <Button Content="&#xE711;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="{StaticResource FontSizeBody}"
                                                Padding="6"
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).DeleteLocationTemplateCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc template.delete}" />
                                        <Button Content="{Binding Name}"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Foreground="{DynamicResource NormalText}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).EditLocationTemplateCommand}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <!-- Item Templates -->
                    <Expander IsExpanded="False" Padding="0">
                        <Expander.Header>
                            <DockPanel>
                                <TextBlock Text="{loc:Loc settings.itemTemplates}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Content="+"
                                        Command="{Binding AddItemTemplateCommand}"
                                        Padding="8,4"
                                        FontSize="{StaticResource FontSizeTitleSmall}"
                                        HorizontalAlignment="Right"
                                        ToolTip.Tip="{loc:Loc template.addTemplate}" />
                            </DockPanel>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{Binding ItemTemplates}" Margin="16,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TemplateListItem">
                                    <DockPanel Margin="0,2">
                                        <Button Content="&#xE711;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="{StaticResource FontSizeBody}"
                                                Padding="6"
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).DeleteItemTemplateCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc template.delete}" />
                                        <Button Content="{Binding Name}"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Foreground="{DynamicResource NormalText}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).EditItemTemplateCommand}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <!-- Lore Templates -->
                    <Expander IsExpanded="False" Padding="0">
                        <Expander.Header>
                            <DockPanel>
                                <TextBlock Text="{loc:Loc settings.loreTemplates}"
                                           Foreground="{DynamicResource NormalText}"
                                           FontSize="{StaticResource FontSizeBodyLarge}"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center" />
                                <Button Content="+"
                                        Command="{Binding AddLoreTemplateCommand}"
                                        Padding="8,4"
                                        FontSize="{StaticResource FontSizeTitleSmall}"
                                        HorizontalAlignment="Right"
                                        ToolTip.Tip="{loc:Loc template.addTemplate}" />
                            </DockPanel>
                        </Expander.Header>
                        <ItemsControl ItemsSource="{Binding LoreTemplates}" Margin="16,4,0,0">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:TemplateListItem">
                                    <DockPanel Margin="0,2">
                                        <Button Content="&#xE711;"
                                                FontFamily="{StaticResource SymbolThemeFontFamily}"
                                                FontSize="{StaticResource FontSizeBody}"
                                                Padding="6"
                                                Background="Transparent"
                                                DockPanel.Dock="Right"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).DeleteLoreTemplateCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="{loc:Loc template.delete}" />
                                        <Button Content="{Binding Name}"
                                                Padding="8,4"
                                                Background="Transparent"
                                                Foreground="{DynamicResource NormalText}"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Left"
                                                Command="{Binding $parent[ItemsControl].((vm:SettingsViewModel)DataContext).EditLoreTemplateCommand}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Keyboard Shortcuts Section ── -->
                <StackPanel x:Name="SectionHotkeys" Spacing="{StaticResource SpacingXL}"
                            IsVisible="{Binding IsHotkeysSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.hotkeys}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <Expander IsExpanded="True" Padding="0">
                        <Expander.Header>
                            <TextBlock Text="{loc:Loc settings.hotkeys}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </Expander.Header>
                        <views:HotkeySettingsView DataContext="{Binding HotkeySettings}" Margin="0,8,0,0" />
                    </Expander>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Updates & Integrations Section ── -->
                <StackPanel x:Name="SectionUpdatesIntegrations" Spacing="{StaticResource SpacingXL}"
                            IsVisible="{Binding IsUpdatesIntegrationsSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.updatesIntegrations}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc update.checkForUpdates}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc update.checkForUpdatesDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding CheckForUpdates}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <!-- Extension update check -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc settings.checkForExtensionUpdates}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.checkForExtensionUpdatesDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding CheckForExtensionUpdates}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <!-- GitHub PAT -->
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc settings.githubToken}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.githubTokenDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <TextBox Text="{Binding GithubToken}"
                                 PasswordChar="●"
                                 HorizontalAlignment="Right"
                                 Width="200"
                                 Watermark="ghp_..." />
                    </DockPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Diagnostics Section ── -->
                <StackPanel x:Name="SectionDiagnostics" Spacing="{StaticResource SpacingXL}"
                            IsVisible="{Binding IsDiagnosticsSectionVisible}">
                    <TextBlock Text="{loc:Loc settings.diagnostics}"
                               FontSize="{StaticResource FontSizeBodySmall}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource SubtleText}"
                               LetterSpacing="1" />

                    <DockPanel>
                        <StackPanel DockPanel.Dock="Left" Spacing="{StaticResource SpacingTightest}" Width="360">
                            <TextBlock Text="{loc:Loc settings.diagnosticLogging}"
                                       Foreground="{DynamicResource NormalText}"
                                       FontSize="{StaticResource FontSizeBodyLarge}" />
                            <TextBlock Text="{loc:Loc settings.diagnosticLoggingDesc}"
                                       Foreground="{DynamicResource SubtleText}"
                                       FontSize="{StaticResource FontSizeBodySmall}"
                                       TextWrapping="Wrap" />
                        </StackPanel>
                        <ToggleSwitch IsChecked="{Binding DiagnosticLoggingEnabled}"
                                      HorizontalAlignment="Right"
                                      OnContent=""
                                      OffContent="" />
                    </DockPanel>

                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource SpacingMedium}">
                        <Button Content="{loc:Loc settings.openLogFolder}"
                                Command="{Binding OpenLogFolderCommand}" />
                        <Button Content="{loc:Loc settings.openCurrentLog}"
                                Command="{Binding OpenCurrentLogCommand}" />
                        <Button Content="{loc:Loc settings.clearLogs}"
                                Command="{Binding ClearLogsCommand}" />
                    </StackPanel>

                    <Border Height="1" Background="{DynamicResource RibbonGroupBorder}" Margin="0,8,0,0" />
                </StackPanel>

                <!-- ── Extension Settings Sections ── -->
                <ItemsControl x:Name="SectionExtensions" ItemsSource="{Binding ExtensionSettingsPages}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:ExtensionSettingsPageVM">
                            <StackPanel Spacing="{StaticResource SpacingLarge}" Margin="0,16,0,0">
                                <TextBlock Text="{Binding Category}"
                                           FontSize="{StaticResource FontSizeBodySmall}"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SubtleText}"
                                           LetterSpacing="1" />
                                <ContentControl Content="{Binding View}" />
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>

    </Grid>
    </Border>
</UserControl>
