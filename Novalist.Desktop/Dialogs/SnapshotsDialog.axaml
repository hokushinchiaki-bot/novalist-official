<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="using:Novalist.Desktop.Localization"
        xmlns:dlg="using:Novalist.Desktop.Dialogs"
        mc:Ignorable="d"
        x:Class="Novalist.Desktop.Dialogs.SnapshotsDialog"
        Width="780"
        MaxHeight="640"
        Focusable="True">
    <Border Background="Transparent" Padding="24">
        <DockPanel>
            <StackPanel DockPanel.Dock="Top" Spacing="{StaticResource SpacingSmall}" Margin="0,0,0,12">
                <TextBlock Text="{loc:Loc snapshots.title}"
                           FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource NormalText}" />
                <TextBlock x:Name="SceneTitleText"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource SubtleText}" />
            </StackPanel>

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="{StaticResource SpacingMedium}"
                        Margin="0,16,0,0">
                <Button Content="{loc:Loc dialog.close}"
                        Padding="16,8"
                        Click="OnClose" />
            </StackPanel>

            <Grid RowDefinitions="Auto,*">
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <Button DockPanel.Dock="Right"
                            Content="{loc:Loc snapshots.take}"
                            Classes="primary"
                            Padding="14,6"
                            IsDefault="True"
                            Click="OnTakeSnapshot" />
                    <TextBox x:Name="LabelBox"
                             Watermark="{loc:Loc snapshots.labelWatermark}"
                             Margin="0,0,8,0" />
                </DockPanel>

                <Border Grid.Row="1"
                        BorderBrush="{DynamicResource ExplorerBorder}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource RadiusSmall}">
                    <ListBox x:Name="SnapshotList"
                             Background="Transparent"
                             SelectionMode="Single">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="dlg:SnapshotsDialog+SnapshotRow">
                                <StackPanel Margin="6,4" Spacing="{StaticResource SpacingTighter}">
                                    <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                                        <StackPanel Grid.Column="0" Spacing="{StaticResource SpacingTightest}">
                                            <TextBlock Text="{Binding DisplayLabel}"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource NormalText}" />
                                            <TextBlock Text="{Binding DisplaySubtitle}"
                                                       FontSize="{StaticResource FontSizeBodySmall}"
                                                       Foreground="{DynamicResource SubtleText}" />
                                        </StackPanel>
                                        <Button Grid.Column="1"
                                                Content="{loc:Loc snapshots.compare}"
                                                Padding="10,4"
                                                Margin="0,0,4,0"
                                                Click="OnCompareItem"
                                                Tag="{Binding}" />
                                        <Button Grid.Column="2"
                                                Content="{loc:Loc snapshots.restore}"
                                                Padding="10,4"
                                                Margin="0,0,4,0"
                                                Click="OnRestoreItem"
                                                Tag="{Binding}" />
                                        <Button Grid.Column="3"
                                                Content="{loc:Loc snapshots.delete}"
                                                Padding="10,4"
                                                Click="OnDeleteItem"
                                                Tag="{Binding}" />
                                    </Grid>
                                    <Border IsVisible="{Binding IsConfirmingRestore}"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="8">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{loc:Loc snapshots.confirmRestoreMessage}"
                                                       VerticalAlignment="Center"
                                                       FontSize="{StaticResource FontSizeBodySmall}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource NormalText}" />
                                            <Button Grid.Column="1"
                                                    Content="{loc:Loc snapshots.confirmRestore}"
                                                    Classes="primary"
                                                    Padding="10,4"
                                                    Margin="6,0,4,0"
                                                    Click="OnConfirmRestore"
                                                    Tag="{Binding}" />
                                            <Button Grid.Column="2"
                                                    Content="{loc:Loc dialog.cancel}"
                                                    Padding="10,4"
                                                    Click="OnCancelRestore"
                                                    Tag="{Binding}" />
                                        </Grid>
                                    </Border>
                                    <Border IsVisible="{Binding IsConfirmingDelete}"
                                            Background="{DynamicResource CardBackground}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="3"
                                            Padding="8">
                                        <Grid ColumnDefinitions="*,Auto,Auto">
                                            <TextBlock Grid.Column="0"
                                                       Text="{loc:Loc snapshots.confirmDeleteMessage}"
                                                       VerticalAlignment="Center"
                                                       FontSize="{StaticResource FontSizeBodySmall}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource NormalText}" />
                                            <Button Grid.Column="1"
                                                    Content="{loc:Loc snapshots.confirmDelete}"
                                                    Classes="primary"
                                                    Padding="10,4"
                                                    Margin="6,0,4,0"
                                                    Click="OnConfirmDelete"
                                                    Tag="{Binding}" />
                                            <Button Grid.Column="2"
                                                    Content="{loc:Loc dialog.cancel}"
                                                    Padding="10,4"
                                                    Click="OnCancelDelete"
                                                    Tag="{Binding}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <TextBlock Grid.Row="1"
                           x:Name="EmptyText"
                           Text="{loc:Loc snapshots.empty}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SubtleText}"
                           IsVisible="False" />
            </Grid>
        </DockPanel>
    </Border>
</UserControl>
