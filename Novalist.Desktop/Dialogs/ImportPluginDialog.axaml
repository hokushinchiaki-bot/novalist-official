<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:loc="using:Novalist.Desktop.Localization"
        mc:Ignorable="d"
        x:Class="Novalist.Desktop.Dialogs.ImportPluginDialog"
        Width="520"
        Focusable="True">
    <Border Background="Transparent"
            Padding="24">
        <DockPanel>
            <!-- Buttons -->
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Spacing="{StaticResource SpacingMedium}"
                        Margin="0,16,0,0">
                <Button x:Name="CancelButton"
                        Content="{loc:Loc dialog.cancel}"
                        Padding="16,8"
                        Click="OnCancel" />
                <Button x:Name="ImportButton"
                        Content="{loc:Loc import.startImport}"
                        Classes="primary"
                        Click="OnImport"
                        IsDefault="True" />
            </StackPanel>

            <StackPanel Spacing="{StaticResource SpacingLarge}">
                <TextBlock Text="{loc:Loc import.title}"
                           FontSize="{StaticResource FontSizeTitle}"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource NormalText}" />

                <TextBlock Text="{loc:Loc import.description}"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource SubtleText}"
                           TextWrapping="Wrap" />

                <!-- Configuration Panel -->
                <StackPanel x:Name="ConfigPanel" Spacing="{StaticResource SpacingMedium}">
                    <!-- Vault Folder -->
                    <StackPanel Spacing="{StaticResource SpacingTighter}">
                        <TextBlock Text="{loc:Loc import.vaultFolder}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource DimText}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     x:Name="VaultPathBox"
                                     IsReadOnly="True"
                                     Watermark="{loc:Loc import.vaultFolderPlaceholder}" />
                            <Button Grid.Column="1"
                                    x:Name="BrowseVaultButton"
                                    Content="{loc:Loc welcome.browse}"
                                    Click="OnBrowseVault"
                                    Margin="4,0,0,0" />
                        </Grid>
                    </StackPanel>

                    <!-- Plugin Project Selector (visible only when multiple projects detected) -->
                    <StackPanel x:Name="ProjectSelectorPanel" Spacing="{StaticResource SpacingTighter}" IsVisible="False">
                        <TextBlock Text="{loc:Loc import.selectProject}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource DimText}" />
                        <ComboBox x:Name="ProjectComboBox"
                                  HorizontalAlignment="Stretch"
                                  SelectionChanged="OnProjectSelectionChanged" />
                    </StackPanel>

                    <!-- Project Name -->
                    <StackPanel Spacing="{StaticResource SpacingTighter}">
                        <TextBlock Text="{loc:Loc welcome.projectName}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource DimText}" />
                        <TextBox x:Name="ProjectNameBox"
                                 Watermark="{loc:Loc welcome.projectNamePlaceholder}"
                                 MaxLength="100" />
                    </StackPanel>

                    <!-- Book Name -->
                    <StackPanel Spacing="{StaticResource SpacingTighter}">
                        <TextBlock Text="{loc:Loc welcome.bookName}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource DimText}" />
                        <TextBox x:Name="BookNameBox"
                                 Watermark="{loc:Loc welcome.bookNamePlaceholder}"
                                 MaxLength="100" />
                    </StackPanel>

                    <!-- Output Location -->
                    <StackPanel Spacing="{StaticResource SpacingTighter}">
                        <TextBlock Text="{loc:Loc import.outputLocation}"
                                   FontSize="{StaticResource FontSizeBody}"
                                   Foreground="{DynamicResource DimText}" />
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     x:Name="OutputPathBox"
                                     IsReadOnly="True"
                                     Watermark="{loc:Loc welcome.locationPlaceholder}" />
                            <Button Grid.Column="1"
                                    Content="{loc:Loc welcome.browse}"
                                    Click="OnBrowseOutput"
                                    Margin="4,0,0,0" />
                        </Grid>
                    </StackPanel>
                </StackPanel>

                <!-- Progress Panel -->
                <StackPanel x:Name="ProgressPanel" Spacing="{StaticResource SpacingMedium}" IsVisible="False">
                    <ProgressBar x:Name="ProgressBar"
                                 IsIndeterminate="True"
                                 Height="4" />
                    <TextBlock x:Name="ProgressText"
                               FontSize="{StaticResource FontSizeBody}"
                               Foreground="{DynamicResource SubtleText}" />
                </StackPanel>

                <!-- Error Message -->
                <TextBlock x:Name="ErrorText"
                           FontSize="{StaticResource FontSizeBody}"
                           Foreground="{DynamicResource DangerBrush}"
                           TextWrapping="Wrap"
                           IsVisible="False" />
            </StackPanel>
        </DockPanel>
    </Border>
</UserControl>
